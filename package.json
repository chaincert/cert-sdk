{
  "name": "@cert-id/sdk",
  "version": "0.1.16",
  "description": "Official SDK for the CertID Sovereign Identity Layer - hardware biometric verification on Arbitrum Stylus",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "contracts",
    "bin"
  ],
  "bin": {
    "cert-verify": "bin/cert-verify.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "certid",
    "identity",
    "webauthn",
    "passkeys",
    "arbitrum",
    "stylus",
    "hardware-enclave",
    "attestation",
    "verification"
  ],
  "author": "CertID Engineering <dev@c3rt.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cert-id/cert-sdk.git"
  },
  "homepage": "https://cert-id.org",
  "bugs": {
    "url": "https://github.com/cert-id/cert-sdk/issues"
  },
  "dependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "solc": "^0.8.20",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "overrides": {
    "minimatch@^3.0.0": "^3.1.4",
    "minimatch@^5.0.0": "^5.1.8",
    "minimatch@^9.0.0": "^9.0.7",
    "rollup": "^4.59.0",
    "serialize-javascript": "^6.0.3"
  }
}

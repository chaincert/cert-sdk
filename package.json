{
  "name": "@certid/sdk",
  "version": "1.1.0",
  "description": "Official SDK for the CertID Sovereign Identity Layer - hardware biometric verification on Arbitrum",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "contracts"
  ],
  "bin": {
    "cert-verify": "bin/cert-verify.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cert",
    "certblockchain",
    "blockchain",
    "identity",
    "certid",
    "soulbound",
    "sbt",
    "attestation",
    "verification",
    "eas",
    "chain-certify",
    "c3rt"
  ],
  "author": "Cert Blockchain Team <dev@c3rt.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaincertify/cert-sdk.git"
  },
  "homepage": "https://c3rt.org",
  "bugs": {
    "url": "https://github.com/chaincertify/cert-sdk/issues"
  },
  "dependencies": {
    "ethers": "^6.0.0",
    "solc": "^0.8.20"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "ethers": "^6.0.0",
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs"
}